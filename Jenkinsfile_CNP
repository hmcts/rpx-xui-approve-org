@Library("Infrastructure")

import uk.gov.hmcts.contino.AppPipelineDsl
import uk.gov.hmcts.contino.azure.KeyVault
import uk.gov.hmcts.contino.Environment

String type      = 'nodejs'
String product   = 'xui'
String component = 'ao-webapp'
String channel   = '#xui-pipeline'
String playwrightReportDir = 'functional-output/tests/playwright-e2e'
String playwrightApiReportDir = 'functional-output/tests/playwright-api'
String playwrightIntegrationReportDir = 'functional-output/tests/playwright-integration'
String playwrightAccessibilityReportDir = 'functional-output/tests/playwright-a11y'
final String htmlIndexReportFile = 'index.html'
final String ngIntegrationReportDir = 'reports/tests/ngIntegration/'

def yarnBuilder = new uk.gov.hmcts.contino.YarnBuilder(this)

def runPlaywrightFunctionalInParallel = { String environmentLabel ->
    stage("${environmentLabel} Functional Tests (Parallel)") {
        env.PLAYWRIGHT_FUNCTIONAL_PARALLEL_ALREADY_RUN = 'true'
        parallel(
            failFast: false,
            api: {
                stage("${environmentLabel} API Playwright Tests") {
                    yarnBuilder.yarn('test:api:playwright:raw')
                }
            },
            integration: {
                stage("${environmentLabel} Integration Playwright Tests") {
                    yarnBuilder.yarn('test:integration:playwright:raw')
                }
            },
            e2e: {
                stage("${environmentLabel} E2E Playwright Tests") {
                    yarnBuilder.yarn('test:functional:e2e:raw')
                }
            },
            accessibility: {
                stage("${environmentLabel} Accessibility Playwright Tests") {
                    catchError(buildResult: 'SUCCESS', stageResult: 'UNSTABLE') {
                        yarnBuilder.yarn('test:accessibility:playwright:raw')
                    }
                }
            }
        )
    }
}

def runWithFunctionalFailureCapture = { Closure functionalExecution ->
    catchError(stageResult: 'FAILURE') {
        functionalExecution()
    }
}

def resolveParamOrEnv = { String envName ->
    def paramValue = params."${envName}"?.trim()
    return paramValue ?: (env."${envName}"?.trim() ?: '')
}

def applyPlaywrightTagFilterEnv = {
    env.E2E_PW_INCLUDE_TAGS = resolveParamOrEnv('E2E_PW_INCLUDE_TAGS')
    env.E2E_PW_EXCLUDED_TAGS_OVERRIDE = resolveParamOrEnv('E2E_PW_EXCLUDED_TAGS_OVERRIDE')
    env.INTEGRATION_PW_INCLUDE_TAGS = resolveParamOrEnv('INTEGRATION_PW_INCLUDE_TAGS')
    env.INTEGRATION_PW_EXCLUDED_TAGS_OVERRIDE = resolveParamOrEnv('INTEGRATION_PW_EXCLUDED_TAGS_OVERRIDE')
    env.API_PW_INCLUDE_TAGS = resolveParamOrEnv('API_PW_INCLUDE_TAGS')
    env.API_PW_EXCLUDED_TAGS_OVERRIDE = resolveParamOrEnv('API_PW_EXCLUDED_TAGS_OVERRIDE')
    env.A11Y_PW_INCLUDE_TAGS = resolveParamOrEnv('A11Y_PW_INCLUDE_TAGS')
    env.A11Y_PW_EXCLUDED_TAGS_OVERRIDE = resolveParamOrEnv('A11Y_PW_EXCLUDED_TAGS_OVERRIDE')
}

def logPlaywrightTagFilterEnv = { String contextLabel ->
    echo([
        "[playwright-tags] ${contextLabel}",
        "E2E include=${env.E2E_PW_INCLUDE_TAGS ?: '<none>'} exclude=${env.E2E_PW_EXCLUDED_TAGS_OVERRIDE ?: '<none>'}",
        "Integration include=${env.INTEGRATION_PW_INCLUDE_TAGS ?: '<none>'}" +
            " exclude=${env.INTEGRATION_PW_EXCLUDED_TAGS_OVERRIDE ?: '<none>'}",
        "API include=${env.API_PW_INCLUDE_TAGS ?: '<none>'} exclude=${env.API_PW_EXCLUDED_TAGS_OVERRIDE ?: '<none>'}",
        "A11Y include=${env.A11Y_PW_INCLUDE_TAGS ?: '<none>'} exclude=${env.A11Y_PW_EXCLUDED_TAGS_OVERRIDE ?: '<none>'}"
    ].join(' | '))
}

def branchesToSync = ['demo', 'perftest', 'ithc']

String vaultSecretsKey = 'rpx-' + '$' + '{env}'

def secrets = [
