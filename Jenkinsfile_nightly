    // Keep master scheduled, but leave nightly-dev and PR branches manual-only.
    pipelineTriggers(env.BRANCH_NAME == 'master' ? [cron('15 17 * * 1-5')] : []),
    parameters([
        string(
            name: e2ePwIncludeTagsEnvName,
            defaultValue: '',
            description: 'Optional E2E include tags (space/comma separated)'
        ),
        string(
            name: e2ePwExcludedTagsOverrideEnvName,
            defaultValue: '',
            description: 'Optional E2E excluded tags override (@none clears file defaults)'
        ),
        string(
            name: integrationPwIncludeTagsEnvName,
            defaultValue: '',
            description: 'Optional integration include tags (space/comma separated)'
        ),
        string(
            name: integrationPwExcludedTagsOverrideEnvName,
            defaultValue: '',
            description: 'Optional integration excluded tags override (@none clears file defaults)'
        ),
        string(
            name: apiPwIncludeTagsEnvName,
            defaultValue: '',
            description: 'Optional API include tags (space/comma separated)'
        ),
        string(
            name: apiPwExcludedTagsOverrideEnvName,
            defaultValue: '',
            description: 'Optional API excluded tags override (@none clears file defaults)'
        ),
        string(
            name: a11yPwIncludeTagsEnvName,
            defaultValue: '',
            description: 'Optional accessibility include tags (space/comma separated)'
        ),
        string(
            name: a11yPwExcludedTagsOverrideEnvName,
            defaultValue: '',
            description: 'Optional accessibility excluded tags override (@none clears file defaults)'
        ),
        booleanParam(
            name: runAccessibilityTestsParamName,
            defaultValue: true,
            description: 'Run the unified accessibility Playwright pack (axe, WAVE-like and screen-reader checks)'
        )
    ])
])

@Library("Infrastructure@2.4.5")

String type      = 'nodejs'
String product   = 'xui'
String component = 'webapp'
String channel   = '#xui-pipeline'
String playwrightReportDir = 'functional-output/tests/playwright-e2e/odhin-report'
String playwrightApiReportDir = 'functional-output/tests/playwright-api/odhin-report'
String playwrightIntegrationReportDir = 'functional-output/tests/playwright-integration/odhin-report'
String playwrightNightlyReportDir = 'functional-output/tests/playwright-nightly/odhin-report'
String playwrightAccessibilityReportDir = 'functional-output/tests/playwright-accessibility/odhin-report'
String playwrightApiReportFile = 'xui-ao-playwright-api.html'
String playwrightIntegrationReportFile = 'xui-ao-playwright-integration.html'
String playwrightNightlyReportFile = 'xui-ao-playwright-nightly.html'

uk.gov.hmcts.contino.YarnBuilder yarnBuilder = new uk.gov.hmcts.contino.YarnBuilder(this)

Closure<Boolean> shouldRunAccessibilityTests = {
    Object configured = params."${runAccessibilityTestsParamName}"
    return configured == null ? true : configured.toString().toBoolean()
}

Closure<Void> runPlaywrightFunctionalInParallel = {
    stage('Nightly Functional Tests (Parallel)') {
        env.PLAYWRIGHT_FUNCTIONAL_PARALLEL_ALREADY_RUN = 'true'
        Map<String, Object> playwrightBranches = [
            failFast: false,
            api: {
                stage('Nightly API Playwright Tests') {
                    yarnBuilder.yarn('test:api:playwright:raw')
                }
            },
            integration: {
                stage('Nightly Integration Playwright Tests') {
                    yarnBuilder.yarn('test:integration:playwright:raw')
                }
            },
            crossBrowser: {
                stage('Nightly Cross Browser Playwright Tests') {
                    yarnBuilder.yarn('test:crossbrowser')
                }
            }
        ]

        if (shouldRunAccessibilityTests()) {
            playwrightBranches.accessibility = {
                stage('Nightly Accessibility Playwright Tests') {
                    catchError(buildResult: 'SUCCESS', stageResult: 'UNSTABLE') {
                        yarnBuilder.yarn('test:accessibility:playwright')
                    }
                }
            }
        } else {
            echo "[playwright-a11y] Nightly Accessibility Playwright Tests skipped; ${runAccessibilityTestsParamName}=false"
        }

        parallel(playwrightBranches)
    }
}

Closure<String> resolveParamOrEnv = { String envName ->
    String paramValue = params."${envName}"?.trim()
    return paramValue ?: (env."${envName}"?.trim() ?: '')
}

Closure<Void> applyPlaywrightTagFilterEnv = {
    playwrightTagFilterEnvNames.each { String envName ->
        env."${envName}" = resolveParamOrEnv(envName)
    }
}

Closure<Void> logPlaywrightTagFilterEnv = { String contextLabel ->
    String e2eInclude = env.E2E_PW_INCLUDE_TAGS ?: noneTagFallback
    String e2eExclude = env.E2E_PW_EXCLUDED_TAGS_OVERRIDE ?: noneTagFallback
    String integrationInclude = env.INTEGRATION_PW_INCLUDE_TAGS ?: noneTagFallback
    String integrationExclude = env.INTEGRATION_PW_EXCLUDED_TAGS_OVERRIDE ?: noneTagFallback
    String apiInclude = env.API_PW_INCLUDE_TAGS ?: noneTagFallback
    String apiExclude = env.API_PW_EXCLUDED_TAGS_OVERRIDE ?: noneTagFallback
    String a11yInclude = env.A11Y_PW_INCLUDE_TAGS ?: noneTagFallback
    String a11yExclude = env.A11Y_PW_EXCLUDED_TAGS_OVERRIDE ?: noneTagFallback

    echo([
        "[playwright-tags] ${contextLabel}",
        "E2E include=${e2eInclude} exclude=${e2eExclude}",
        "Integration include=${integrationInclude} exclude=${integrationExclude}",
        "API include=${apiInclude} exclude=${apiExclude}",
        "A11Y include=${a11yInclude} exclude=${a11yExclude}",
        "A11Y enabled=${shouldRunAccessibilityTests()}"
    ].join(' | '))
}

String vaultSecretsKey = 'rpx-' + '$' + '{env}'

Map<String, List<Map<String, Object>>> secrets = [
    (vaultSecretsKey): [
    secret('approve-org-admin-username', 'APPROVE_ORG_ADMIN_USERNAME'),
    secret('approve-org-admin-password', 'APPROVE_ORG_ADMIN_PASSWORD'),
    secret('test-api-email-adminuser', 'APPROVE_ORG_API_USERNAME'),
    secret('test-api-password-adminuser', 'APPROVE_ORG_API_PASSWORD'),
    secret('test-roo-username', 'TEST_ROO_EMAIL'),
    secret('test-roo-password', 'TEST_ROO_PASSWORD'),
    secret('appinsights-connection-string-ao', 'APPINSIGHTS_CONNECTION_STRING'),
    secret('launch-darkly-client-id', 'LAUNCH_DARKLY_CLIENT_ID')
  ]
]

static Map<String, Object> secret(String secretName, String envVar) {
    [ $class: 'AzureKeyVaultSecret',
    secretType: 'Secret',
    name: secretName,
    version: '',
    envVariable: envVar
  ]
}

withNightlyPipeline(type, product, component) {
    enableSlackNotifications(channel)
    loadVaultSecrets(secrets)
    env.FUNCTIONAL_TESTS_WORKERS = '5'
    applyPlaywrightTagFilterEnv()
    logPlaywrightTagFilterEnv('pipeline env')
    env.PLAYWRIGHT_RELEASE_TAG = 'nightly'
    // enableFortifyScan('rpx-aat')
    enableFullFunctionalTest(60)
    // mutation test no longer running as it is not required
    // enableMutationTest()
    env.TEST_URL = 'https://administer-orgs.aat.platform.hmcts.net'
    afterSuccess('checkout') { sh 'yarn cache clean' }
    afterSuccess('build') {
        sh 'npm run build'
        publishHTML([
            allowMissing         : true,
            alwaysLinkToLastBuild: true,
            keepAll              : true,
            reportDir            : 'test/reports/lint/node/',
            reportFiles          : htmlIndexReportFile,
            reportName           : 'node lint Report'
        ])
        publishHTML([
            allowMissing         : true,
            alwaysLinkToLastBuild: true,
            keepAll              : true,
            reportDir            : 'test/reports/lint/ng/',
            reportFiles          : htmlIndexReportFile,
            reportName           : 'ng lint Report'
        ])
    }

    afterSuccess('fortify-scan') {
        steps.archiveArtifacts allowEmptyArchive: true, artifacts: '**/Fortify Scan/**/*'
    }

    before('fullFunctionalTest') {
        catchError(stageResult: 'FAILURE') {
            runPlaywrightFunctionalInParallel()
        }
    }

    afterAlways('fullFunctionalTest') {
        publishHTML([
            allowMissing         : true,
            alwaysLinkToLastBuild: true,
            keepAll              : true,
            reportDir            : playwrightApiReportDir,
            reportFiles          : playwrightApiReportFile,
            reportName           : 'XUI Approve Organisation Full functional API Playwright Tests'
        ])

        publishHTML([
            allowMissing         : true,
            alwaysLinkToLastBuild: true,
            keepAll              : true,
            reportDir            : playwrightIntegrationReportDir,
            reportFiles          : playwrightIntegrationReportFile,
            reportName           : 'XUI Approve Organisation Full functional Integration Playwright Tests'
        ])

        if (shouldRunAccessibilityTests()) {
            publishHTML([
                allowMissing         : true,
                alwaysLinkToLastBuild: true,
                keepAll              : true,
                reportDir            : "${playwrightAccessibilityReportDir}/",
                reportFiles          : playwrightAccessibilityReportFile,
                reportName           : 'XUI Approve Organisation Full functional Accessibility Playwright Tests'
            ])
        } else {
            echo "[playwright-a11y] Full functional Accessibility Playwright Test report publish skipped because ${runAccessibilityTestsParamName}=false"
        }

        publishHTML([
            allowMissing         : true,
            alwaysLinkToLastBuild: true,
            keepAll              : true,
            reportDir            : playwrightNightlyReportDir,
            reportFiles          : playwrightNightlyReportFile,
            reportName           : 'XUI Approve Organisation Cross Browser Tests'
        ])
    }

    /* afterSuccess('mutationTest') {
        publishHTML([
            allowMissing         : true,
            alwaysLinkToLastBuild: true,
            keepAll              : true,
            reportDir            : "reports/tests/mutation/node/",
            reportFiles          : htmlIndexReportFile,
            reportName           : 'XUI Approve Organisation Mutation tests'
        ])
    } */

    afterSuccess('securityScan') {
            publishHTML([
            allowMissing         : true,
            alwaysLinkToLastBuild: true,
            keepAll              : true,
            reportDir            : 'reports/tests/',
            reportFiles          : 'activescan.html',
            reportName           : 'XUIAO ZAP Security Scan Report'
        ])
    }
}
