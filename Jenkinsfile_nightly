#!groovy

final String e2ePwIncludeTagsEnvName = 'E2E_PW_INCLUDE_TAGS'
final String e2ePwExcludedTagsOverrideEnvName = 'E2E_PW_EXCLUDED_TAGS_OVERRIDE'
final String integrationPwIncludeTagsEnvName = 'INTEGRATION_PW_INCLUDE_TAGS'
final String integrationPwExcludedTagsOverrideEnvName = 'INTEGRATION_PW_EXCLUDED_TAGS_OVERRIDE'
final String apiPwIncludeTagsEnvName = 'API_PW_INCLUDE_TAGS'
final String apiPwExcludedTagsOverrideEnvName = 'API_PW_EXCLUDED_TAGS_OVERRIDE'
final String a11yPwIncludeTagsEnvName = 'A11Y_PW_INCLUDE_TAGS'
final String a11yPwExcludedTagsOverrideEnvName = 'A11Y_PW_EXCLUDED_TAGS_OVERRIDE'
final String runAccessibilityTestsParamName = 'RUN_ACCESSIBILITY_TESTS'
final String noneTagFallback = '<none>'
final String htmlIndexReportFile = 'index.html'
final String playwrightAccessibilityReportFile = 'xui-ao-playwright-accessibility.html'

final List<String> playwrightTagFilterEnvNames = [
    e2ePwIncludeTagsEnvName,
    e2ePwExcludedTagsOverrideEnvName,
    integrationPwIncludeTagsEnvName,
    integrationPwExcludedTagsOverrideEnvName,
    apiPwIncludeTagsEnvName,
    apiPwExcludedTagsOverrideEnvName,
    a11yPwIncludeTagsEnvName,
    a11yPwExcludedTagsOverrideEnvName
]

properties([
    [
        $class       : 'GithubProjectProperty',
        displayName  : 'Expert UI Approve Organisations',
        projectUrlStr: 'https://github.com/hmcts/rpx-xui-approve-org'
