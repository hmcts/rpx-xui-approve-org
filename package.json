{
  "name": "organisation-manager",
  "version": "0.0.0",
  "workspaces": [
    "api"
  ],
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "build": "export NODE_OPTIONS=--openssl-legacy-provider; yarn build:prod && yarn build:node",
    "build:docker": "docker build . -t rpx-xui-approve-org",
    "build:ng": "ng build",
    "build:node": "cd api && yarn build",
    "build:prod": "ng build --configuration production",
    "clean": "rm -f -r node_modules && rm -f yarn.lock",
    "env:populate": "./scripts/populate-env-from-keyvault.sh ${ENVIRONMENT:-aat}",
    "env:populate:aat": "./scripts/populate-env-from-keyvault.sh aat",
    "env:populate:demo": "./scripts/populate-env-from-keyvault.sh demo",
    "e2e": "ng e2e",
    "fortifyScan": "./test/java/gradlew -p test/java fortifyScan",
    "lint": "yarn lint:ng && yarn lint:node",
    "lint:ng": "yarn eslint src",
    "lint:node": "yarn eslint api",
    "lint:test": "yarn eslint playwright_tests",
    "ng": "ng",
    "pre-push": "yarn lint && yarn build:prod && ng test organisation-manager --code-coverage",
    "prepush": "bash ./bin/prepush.sh",
    "prepare": "husky",
    "publish-pact": "NODE_PATH=. NODE_CONFIG_DIR=./config LOG_LEVEL=error DOTENV_CONFIG_DEFAULTS=./api/.env.defaults node -r ts-node/register -r dotenv-extended/config api/test/pact/publish/publish.ts",
    "run:docker": "yarn build:docker && yarn start:docker",
    "sonar-scan": "node_modules/sonar-scanner/bin/sonar-scanner",
    "start": "node ./dist/organisation-manager/api/server.bundle.js",
    "start:docker": "docker run -p 3000:3000 --env-file ./api/.env.defaults --env NODE_CONFIG_DIR= -v /mnt/secrets:/mnt/secrets rpx-xui-approve-org",
    "start:ng": "ng serve --port 3000 --host 0.0.0.0 --proxy-config proxy.config.json",
    "start:node": "cd api && yarn watch",
    "test": "yarn test:ng",
    "test:a11y1": "echo \"Accessibility suite runs in the dedicated Playwright Accessibility CI stage\"",
    "test:a11y": "echo \"Accessibility suite runs in the dedicated Playwright Accessibility CI stage\"",
    "test:api:playwright": "yarn playwright install chromium && yarn test:api:playwright:raw",
    "test:api:playwright:raw": "PW_AUTH_SESSION_USER=api npx playwright test -c playwright-api.config.ts",
    "test:integration:playwright": "yarn playwright install chromium && yarn test:integration:playwright:raw",
    "test:integration:playwright:raw": "npx playwright test -c playwright-integration.config.ts",
    "test:accessibility:playwright": "yarn playwright install chromium && node scripts/run-playwright-accessibility.cjs",
    "test:accessibility:playwright:raw": "npx playwright test -c playwright-accessibility.config.ts",
    "test:wave-a11y:playwright": "node scripts/run-playwright-wave-a11y.cjs",
    "test:lighthouse-a11y:playwright": "node scripts/run-playwright-lighthouse-a11y.cjs",
    "test:can-i-deploy:consumer": "export VERSION=$(git rev-parse --short HEAD) && SSL_CERT_FILE=api/test/pact/cer/ca-bundle.crt pact-broker can-i-deploy --pacticipant 'xui_approveorg' --version ${VERSION} --broker-base-url https://pact-broker.platform.hmcts.net",
    "test:coverage": "echo 'not implemented'",
    "test:coverage:ng": "ng test organisation-manager --code-coverage --watch",
    "test:coverage:node": "cd api && yarn coverage",
    "test:crossbrowser": "yarn playwright install --with-deps && yarn playwright install webkit && yarn playwright install firefox && npx playwright test -c playwright-nightly.config.ts",
    "test:fullfunctional": "yarn test:functional && echo 'Protractor tests removed - using Playwright instead'",
    "test:functional": "sh -c 'if [ \"${PLAYWRIGHT_FUNCTIONAL_PARALLEL_ALREADY_RUN}\" = \"true\" ]; then echo \"Skipping test:functional because Jenkins ran Playwright API + integration + E2E in parallel\"; exit 0; fi; yarn test:functional:e2e'",
    "test:functional:parallel": "yarn playwright install chromium && sh -c 'yarn test:functional:e2e:raw & pid_e2e=$!; yarn test:api:playwright:raw & pid_api=$!; yarn test:integration:playwright:raw & pid_integration=$!; wait \"$pid_e2e\"; e2e_status=$?; wait \"$pid_api\"; api_status=$?; wait \"$pid_integration\"; integration_status=$?; [ \"$e2e_status\" -eq 0 ] && [ \"$api_status\" -eq 0 ] && [ \"$integration_status\" -eq 0 ]'",
    "test:functional:e2e": "yarn playwright install chromium && yarn test:functional:e2e:raw",
    "test:functional:e2e:raw": "npx playwright test -c playwright.config.ts",
    "test:mutation": "NODE_CONFIG_DIR=./config stryker run stryker.node.conf.js ",
    "test:ng": "ng test",
    "test:ng:watch": "ng test --watch",
    "test:node": "cd api && yarn test",
    "test:node:watch": "cd api && yarn test:watch",
    "test-pact": "NODE_PATH=. NODE_CONFIG_DIR=./config LOG_LEVEL=error DOTENV_CONFIG_DEFAULTS=./api/.env.defaults mocha --timeout 10000 -r ts-node/register -r dotenv-extended/config api/test/pact/pact-tests/**/*.spec.ts",
    "test:pact:run-and-publish": "yarn test-pact && yarn publish-pact",
    "test:smoke": "yarn playwright install chromium && E2E_PW_INCLUDE_TAGS='@smoke' E2E_PW_EXCLUDED_TAGS_OVERRIDE='@none' npx playwright test playwright_tests/e2e/login.test.ts -c playwright.config.ts"
  },
  "private": true,
