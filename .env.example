# Playwright credentials loaded from Azure Key Vault by tags.e2e mapping
APPROVE_ORG_ADMIN_USERNAME=
APPROVE_ORG_ADMIN_PASSWORD=
APPROVE_ORG_API_USERNAME=
APPROVE_ORG_API_PASSWORD=
TEST_ROO_EMAIL=
TEST_ROO_PASSWORD=

# Loaded only from the exact AO secret; APPROVE_ORG_PLAYWRIGHT_GLOBAL_EXCLUDED_TAGS is inventory metadata.
# Additive API/E2E/integration exclusions. Use spaces between tags; @none is a no-op.
PLAYWRIGHT_GLOBAL_EXCLUDED_TAGS=@none
# Set true only while verifying a fix for a globally excluded test.
PLAYWRIGHT_IGNORE_GLOBAL_EXCLUDES=
